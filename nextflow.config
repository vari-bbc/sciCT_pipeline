params {
    output_dir = "results"
}

profiles {
    slurm {
        process.executor = 'slurm'
        process.queue = 'bbc'
        process.memory = 200.GB
        process.cpus = 4
    }
}
conda {
    enabled = true
}
env.NXF_CONDA_CACHEDIR = "$baseDir/.conda"
process {
    tmpDir = "$baseDir/tmp"
    conda = "envs/environment.yml"
    withName: RUN_DEMUX {
        publishDir = [ path: params.output_dir, mode: 'copy', overwrite: true ]
  }
}